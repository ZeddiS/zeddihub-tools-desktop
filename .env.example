# ZeddiHub Tools Desktop – konfigurace pro automatizaci
# Zkopíruj tento soubor jako .env a vyplň hodnoty.
# .env je v .gitignore – NIKDY jej necommituj!

# GitHub Fine-grained Personal Access Token
# Vytvoř: https://github.com/settings/tokens?type=beta
# Expire: 90 dní (nebo dle preference)
# Repository access: Only select repositories → ZeddiS/zeddihub-tools-desktop
# Repository permissions:
#   - Contents: Read and write   (tag push, release create, commit push)
#   - Issues: Read and write      (čtení/psaní issues)
#   - Pull requests: Read and write
#   - Metadata: Read-only         (automaticky required)
GITHUB_TOKEN=github_pat_ZDE_VLOZ_SVUJ_TOKEN

# Repo a větev
GITHUB_OWNER=ZeddiS
GITHUB_REPO=zeddihub-tools-desktop
GITHUB_DEFAULT_BRANCH=master

# Volitelné – identita pro `git commit` když Claude pushuje změny
GIT_AUTHOR_NAME=tvoje-jmeno
GIT_AUTHOR_EMAIL=tvuj@email.cz

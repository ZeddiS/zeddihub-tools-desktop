# =========================================================================
# ZeddiHub Tools Desktop — .gitignore
# Cil: na GitHubu je POUZE source desktop aplikace.
# Webhosting (PHP admin, data), Google Apps Script, build artefakty,
# lokalni cache a tajemstvi ZUSTAVAJI lokalne.
# =========================================================================

# --- Build artefakty ---
dist/
build/
*.spec
!ZeddiHubTools.spec

# --- Python cache ---
__pycache__/
*.pyc
*.pyo

# --- IDE/editor ---
.vscode/
.idea/

# --- Runtime data (uzivatelska) ---
/data/
*.enc
Thumbs.db

# --- Claude / agent worktrees ---
.claude/

# --- Assets stazene z CDN za behu (negenerujeme je do repa) ---
assets/banner.png
assets/logo.png
assets/web_favicon.ico

# --- Serverova cast (od v1.7.4 v samostatnem repu zeddihub-tools-website) ---
# Drzime v .gitignore pro pripad, ze nekdo obnovi junction jmenem webhosting.
webhosting/

# --- Google Apps Script (neni app source) ---
ZeddiHub App/

# --- Obsoletni/pracovni soubory ---
backlog_export_*.csv
RELEASE_NOTES_v*.md
release_notes_v*.md
release_1_8_0.*
security_cleanup.bat
release_1_8_0_manual.cmd
CLAUDE.md

# =========================================================================
# Secrets
# POZOR: .gitignore neCHRANI tajemstvi - pouze zamezuje pridani souboru.
# Hodnotu tokenu NIKDY nevkladat do .gitignore jako radek!
# =========================================================================
.env
.env.local
*.token
.gh_token

# ZeddiHub Builder
_launch_builder.bat
.zeddibuild.local.json
_build_tmp.spec
